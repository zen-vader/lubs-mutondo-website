# Copy this file to ".env" for local testing.
# On Railway, add these same values under Project -> Variables instead
# (do not upload a real .env file to GitHub or Railway).

PORT=3000

# Which frontend(s) are allowed to call this API.
# Use "*" while testing, then lock it down to your real site URL once it's live.
ALLOWED_ORIGIN=*

# A shared secret your frontend must send in the "x-api-key" header.
# Make this up yourself - any long random string. Prevents strangers from
# using your backend to spam email through your Gmail account.
API_KEY=change-this-to-a-long-random-string

# --- Gmail sending account ---
# GMAIL_USER must have 2-Step Verification turned on, and GMAIL_APP_PASSWORD
# must be an "App Password" generated for it (NOT the normal Gmail password).
# Google Account -> Security -> 2-Step Verification -> App passwords
GMAIL_USER=lubsmutondoltd@gmail.com
GMAIL_APP_PASSWORD=your16characterapppassword

# --- Company details shown on the PDF ---
COMPANY_NAME=Lubs Mutondo Limited
COMPANY_ADDRESS=Plot 14B, Kabulonga Road, Lusaka, Zambia
COMPANY_PHONE=+260 97X XXX XXX
COMPANY_EMAIL=lubsmutondoltd@gmail.com

# --- Payment instructions printed on INVOICE PDFs only ---
# Fill these in once you have real mobile money / bank details.
PAYMENT_MOBILE_MONEY=MTN MoMo: 097X XXX XXX (Lubs Mutondo Ltd)
PAYMENT_BANK_DETAILS=Bank: TBC | Account Name: Lubs Mutondo Limited | Account No: TBC
